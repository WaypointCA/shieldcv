{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "allowJs": false,
    "checkJs": false,
    "skipLibCheck": true,
    "strict": true,
    "types": ["svelte", "vite/client", "vitest/globals", "node", "vite-plugin-pwa/client"]
  },
  "include": [".svelte-kit/ambient.d.ts", "src/**/*.d.ts", "src/**/*.ts", "src/**/*.svelte", "../../docs/**/*.md", "../../types/**/*.d.ts"],
  "exclude": ["build", "node_modules"]
}
